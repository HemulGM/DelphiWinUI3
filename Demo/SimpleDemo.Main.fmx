          object Label4: TLabel
            AutoSize = True
            Position.X = 58.000000000000000000
            Position.Y = 8.000000000000000000
            Size.Width = 423.000000000000000000
            Size.Height = 124.000000000000000000
            Size.PlatformDefault = False
            StyleLookup = 'labelstyle_chat'
            Text = 
              'One morning, when Gregor Samsa woke from troubled dreams, he fou' +
              'nd himself transformed in his bed into a horrible vermin. He lay' +
              ' on his armour-like back, and if he lifted his head a little he ' +
              'could see his brown belly, slightly domed and divided by arches ' +
              'into stiff sections. The bedding was hardly able to cover it and' +
              ' seemed ready to slide off any moment.'
            TabOrder = 1
