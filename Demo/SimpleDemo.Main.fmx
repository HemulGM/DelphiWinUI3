            Size.PlatformDefault = False
            StyleLookup = 'labelstyle_chat_own'
            Text = 
              'A collection of textile samples lay spread out on the table - Sa' +
              'msa was a travelling salesman - and above it there hung a pictur' +
              'e that he had recently cut out of an illustrated magazine and ho' +
              'used in a nice, gilded frame. It showed a lady fitted out with a' +
              ' fur hat and fur boa who sat upright, raising a heavy fur muff t' +
              'hat covered the whole of her lower arm towards the viewer. Grego' +
              'r then turned to look out the window at the dull weather.'
            TabOrder = 1
